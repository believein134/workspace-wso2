<?xml version="1.0" encoding="UTF-8"?>
<template name="ChoreoAuthTokenRetriever" xmlns="http://ws.apache.org/ns/synapse">
    <sequence name="sq_AuthTokenRequest">
        <property action="remove" name="TRANSPORT_HEADERS" scope="axis2"/>
        <!-- Set POST payload for OAuth token request -->
        <payloadFactory media-type="text">
            <format>grant_type=client_credentials&amp;orgHandle=smartbizapitm&amp;scope=apim:api_manage</format>
            <args/>
        </payloadFactory>
        <!-- Set headers for POST request -->
        <property name="ContentType" scope="axis2" type="STRING" value="application/x-www-form-urlencoded"/>
        <header name="Authorization" scope="transport" value="Basic "/>
        <!-- Call the OAuth token endpoint -->
        <call>
            <endpoint key="ChoreoAuthTokenEP"/>
        </call>
        <!-- Capture status & raw response for debugging -->
        <property expression="$axis2:HTTP_SC" name="tokenHttpStatus" scope="default" type="STRING"/>
        <property expression="$body" name="tokenRawResponse" scope="default" type="STRING"/>
        <log level="custom">
            <property expression="$ctx:tokenHttpStatus" name="TOKEN_HTTP_STATUS"/>
            <property expression="substring($ctx:tokenRawResponse, 1, 400)" name="TOKEN_RESPONSE"/>
        </log>
        <!-- Fail if not 200 -->
        <filter regex="[^2]\d\d" source="$axis2:HTTP_SC">
            <then>
                <log level="custom">
                    <property name="TOKEN_ERROR" value="Token endpoint returned non-2xx status"/>
                </log>
                <drop/>
            </then>
            <else/>
        </filter>
        <!-- Extract token -->
        <property expression="json-eval($.access_token)" name="accessToken" scope="default" type="STRING"/>
        <log level="custom">
            <property name="TOKEN_RECEIVED" value="Access token extracted"/>
            <property expression="$ctx:accessToken" name="ACCESS_TOKEN"/>
        </log>
    </sequence>
</template>
