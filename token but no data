 r.applicationName || "", r.applicationId || "", r.apiId || "", callEndDate, "235959", "API", "API", "", "", "MYR", "", "N", "API" ].join("|")); } mc.setProperty("HAS_DATA", rows.length > 0 ? "true" : "false"); mc.setProperty("CSV_ROWS", rows.join("\n")); } catch(e) { mc.getServiceLog().error("Data mapping error: " + e.message); mc.setProperty("HAS_DATA", "false"); } ]]></script> <!-- 8. Continue only if data exists --> <filter regex="true" source="get-property('HAS_DATA')"> <then> <payloadFactory media-type="text"> <format> callDate|callTime|elapsUnit|elapsUom|sourceIdentifier|customField1|customField2|destinationIdentifier|callEndDate|callEndTime|callType|serviceType|customField7|charge|currency|customField6|preRatedIndicator|cdrType $1 </format> <args> <arg evaluator="xml" expression="get-property('CSV_ROWS')"/> </args> </payloadFactory> <!-- File name with timestamp --> <property expression="fn:concat('CDR_API_', get-property('callDate'), '_', get-property('timestamp'), '.csv')" name="fileName" scope="default" type="STRING"/> <!-- Local file write --> <clone sequential="true"> <target> <sequence> <send> <endpoint> <address uri="vfs:file:///C:/Users/MuhammadNabilBinRusl/temp/${fileName}"> <suspendOnFailure> <initialDuration>-1</initialDuration> <progressionFactor>1</progressionFactor> </suspendOnFailure> <markForSuspension> <retriesBeforeSuspension>0</retriesBeforeSuspension> </markForSuspension> </address> </endpoint> </send> </sequence> </target> </clone> <log level="custom"> <property name="INFO" value="CSV generated and uploaded successfully"/> </log> </then> <else> <log level="custom"> <property name="INFO" value="No data – CSV not generated"/> </log> <drop/> </else> </filter> </inSequence> <outSequence/> <faultSequence> <drop/> </faultSequence> </target> </proxy> <?xml version="1.0" encoding="UTF-8"?> <task class="org.apache.synapse.startup.tasks.MessageInjector" group="synapse.simple.quartz" name="SBAScheduler_APIMetering" xmlns="http://ws.apache.org/ns/sy